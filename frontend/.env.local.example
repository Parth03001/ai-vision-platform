# =============================================================================
# Frontend — Local Development Environment
# =============================================================================
# Usage:
#   cp frontend/.env.local.example frontend/.env.local
#   Then restart the React dev server: npm start
#
# This file is safe to commit. .env.local is gitignored (never committed).
# =============================================================================

# Backend API URL — point to wherever your FastAPI server is running
# Local dev (npm start):   http://localhost:8000/api/v1
# Docker Compose:          leave blank (Nginx proxies /api/v1 automatically)
REACT_APP_API_URL=http://localhost:8000/api/v1

# Base URL for uploaded image assets served by FastAPI /uploads static mount
# Local dev (npm start):   http://localhost:8000
# Docker Compose:          leave blank
REACT_APP_BASE_URL=http://localhost:8000
