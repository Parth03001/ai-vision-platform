# ─────────────────────────────────────────────────────────────────────────────
# AI Vision Platform — Environment Variables
# Copy this file to .env and fill in the values.
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ai_vision
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_strong_password_here

# ── Connection pool (optional — defaults are sensible) ────────────────────────
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# ── Redis / Celery ─────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── File storage ──────────────────────────────────────────────────────────────
UPLOAD_DIR=./data/uploads
MODEL_DIR=./data/models

# ── Training ───────────────────────────────────────────────────────────────────
SEED_LEARNING_RATE=0.0005

# ── Optional HuggingFace model paths ──────────────────────────────────────────
GROUNDING_DINO_PATH=../datavision_hf_models/grounding-dino-base
SAM2_PATH=../datavision_hf_models/sam2-hiera-large
SIGLIP_PATH=../datavision_hf_models/siglip-so400m-patch14-384
