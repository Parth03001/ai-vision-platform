# =============================================================================
# AI Vision Platform — Environment Variables
# =============================================================================
# 1. cp .env.example .env
# 2. Fill in all values below
# 3. NEVER commit .env to git
#
# For local development change:
#   POSTGRES_HOST=localhost
#   REDIS_URL=redis://localhost:6379/0   (etc.)
# =============================================================================

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme_strong_password
POSTGRES_DB=ai_vision
POSTGRES_HOST=postgres          # 'postgres' in Docker | 'localhost' for local dev
POSTGRES_PORT=5432

# Connection pool (optional)
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# ── Redis / Celery ─────────────────────────────────────────────────────────────
# Docker: service name 'redis' | Local dev: 'localhost'
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ── File storage ──────────────────────────────────────────────────────────────
UPLOAD_DIR=/app/data/uploads
MODEL_DIR=/app/data/models
# Directory containing pre-downloaded YOLO base weights (baked into Docker image).
# Override only if you mount the weights from an external volume.
YOLO_WEIGHTS_DIR=/app/data/yolo_weights

# ── Training defaults ──────────────────────────────────────────────────────────
SEED_LEARNING_RATE=0.005

# ── HuggingFace model paths ────────────────────────────────────────────────────
# These are baked into the image or can be mounted from the host VM.
# If running on the VM with pre-downloaded models, mount the host path in
# docker-compose.yml volumes and set these paths accordingly.
GROUNDING_DINO_PATH=/app/data/models/grounding-dino-base
SAM2_PATH=/app/data/models/sam2-hiera-large
SIGLIP_PATH=/app/data/models/siglip-so400m-patch14-384
